# Build-time environment variables for SvelteKit
# Real values are loaded at runtime from S3 via entrypoint.sh

# Required for SvelteKit build ($env/static/private imports)
CACHE_TYPE='in-memory'
CACHE_HOST='localhost'
CACHE_PASSWORD=''

# Placeholder URLs (overridden at runtime)
BACKEND_API_URL='https://placeholder-api.example.com/api/v1'
CAREPLAN_BACKEND_API_URL='https://placeholder-careplan.example.com/api/v1'
AWARDS_BACKEND_API_URL='https://placeholder-awards.example.com/api/v1'
API_CLIENT_INTERNAL_KEY='build-placeholder-key'
CLIENT_ID='build-placeholder-client-id'
CAREPLAN_SERVICE_API_KEY='build-placeholder-careplan-key'
AWARDS_SERVICE_API_KEY='build-placeholder-awards-key'
ORIGIN='https://placeholder-admin.example.com'
